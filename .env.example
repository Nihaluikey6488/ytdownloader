PORT=3001
FRONTEND_URL=http://localhost:5173

# Optional: comma-separated origins if frontend and backend are on different domains
# CORS_ORIGIN=https://your-frontend.example.com

# Optional: point the React app to a separate backend URL in production
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: explicit ffmpeg path if it is not on PATH
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional: explicit yt-dlp path if you want to use a system installation
# YT_DLP_PATH=/usr/bin/yt-dlp
